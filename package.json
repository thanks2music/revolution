{
  "name": "revolution",
  "version": "0.0.1",
  "private": true,
  "description": "Next.js Headless CMS Platform on Cloud Run Docker",
  "scripts": {
    "dev": "turbo run dev --filter=frontend-nextjs-headless-cms --filter=@revolution/ai-writer",
    "dev:frontend": "turbo run dev --filter=frontend-nextjs-headless-cms",
    "dev:ai-writer": "turbo run dev --filter=@revolution/ai-writer",
    "build": "turbo run build --filter=frontend-nextjs-headless-cms --filter=@revolution/ai-writer",
    "build:frontend": "turbo run build --filter=frontend-nextjs-headless-cms",
    "build:ai-writer": "turbo run build --filter=@revolution/ai-writer",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "deploy:frontend": "cd apps/frontend && vercel --prod",
    "clean": "turbo run clean && rm -rf .turbo/cache",
    "fresh": "pnpm clean && pnpm install",
    "turbo:version": "pnpm exec turbo --version",
    "turbo:gen": "pnpm exec turbo gen",
    "docs:build-toc": "tsx tools/docs-index.ts",
    "docs:validate": "tsx tools/docs-index.ts && echo 'OK'",
    "docs:sync": "./scripts/sync-docs-to-icloud.sh",
    "docs:create": "./scripts/create-doc-and-sync.sh",
    "prepare": "husky",
    "sync:templates": "./scripts/sync-templates.sh"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsx": "^4.20.4",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0"
  },
  "pnpm": {
    "overrides": {
      "protobufjs@<7.5.5": ">=7.5.5",
      "basic-ftp@<5.3.0": ">=5.3.0",
      "form-data@<2.5.4": ">=2.5.4"
    }
  }
}
