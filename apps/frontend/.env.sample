# ==========================================
# Revolution Frontend - 環境変数テンプレート
# ==========================================
# このファイルをコピーして .env.local を作成してください
#
# 開発環境: .env.local
# 本番環境: Vercel Dashboard で設定（推奨）
# ==========================================

# --------------------------
# サイト基本設定（必須）
# --------------------------
# サイトのベースURL（OGP、サイトマップで使用）
# Production:  https://custom-domain.com
#              → Vercel Dashboard > Settings > Environment Variables で設定済み
# Preview:     自動生成
#              → VERCEL_URL システム環境変数を使用（コード内で動的に取得）
#              → コミット固有: <project>-<hash>-<scope>.vercel.app
#              → ブランチ固有: <project>-git-<branch>-<scope>.vercel.app
# Development: http://localhost:4444
NEXT_PUBLIC_SITE_URL=http://localhost:4444

# サイト名（メタデータで使用）
NEXT_PUBLIC_SITE_NAME=Revolution Platform

# サイト説明（メタデータで使用）
NEXT_PUBLIC_SITE_DESCRIPTION=Descpriotn of your site

# --------------------------
# 開発環境設定（オプション）
# --------------------------
# デバッグモード（開発環境のみ推奨）
# true: 詳細ログを出力、false: 本番モード
NEXT_PUBLIC_DEBUG=false

# --------------------------
# 画像最適化設定（オプション）
# --------------------------
# Next.js Image 最適化で許可するホスト
# Development: localhost
# Production:  Vercel Dashboard で設定推奨
NEXT_PUBLIC_ALLOWED_IMAGE_HOST=localhost

# --------------------------
# Crescendolls 会員機能（Supabase / Drizzle）
# --------------------------
# バックエンド "Crescendolls" は Supabase プロジェクト
# (ref=abqsntbvnuttpyixagob) 上に構築。未登録ユーザーでも記事は読める。
#
# 公開クライアント設定（NEXT_PUBLIC_ プレフィックス。ブラウザに露出してよい）
# - URL は Supabase プロジェクト URL（M0 で必須）
# - PUBLISHABLE_KEY は modern publishable key（anon key の後継、sb_publishable_...）
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# サーバー専用（commit 禁止・ブラウザに露出させない）
# - SECRET_KEY は RLS をバイパスするため用途を限定（username 重複 count 等、M2 以降）
# - DATABASE_URL は postgres-js / Drizzle 用（Transaction pooler 6543、prepare:false。M1 以降）
# - MIGRATION_DATABASE_URL は drizzle-kit / migrate 用（Session pooler 5432、max:1。M1 以降）
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
MIGRATION_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# --------------------------
# CI/CD設定（GitHub Actions用）
# --------------------------
# ビルド時の環境変数検証をスキップ
# GitHub Actions では true に設定
# SKIP_ENV_VALIDATION=true
