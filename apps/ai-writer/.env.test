# Test environment variables
NODE_ENV=test

# Firebase Emulator
FIRESTORE_EMULATOR_HOST=localhost:8088
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
FIREBASE_USE_EMULATOR=true

# Test API Keys (dummy values for testing)
# Note: ANTHROPIC_API_KEY is intentionally NOT defined here. Vision API E2E tests
# (__tests__/e2e/vision-api-pipeline.e2e.test.ts) need it from .env.test.local
# (gitignored, real keys) or CI secrets. With no key, E2E tests skip gracefully
# instead of failing with 401. Unit tests manage process.env.ANTHROPIC_API_KEY
# explicitly inside the test file (claude-vision.service.test.ts).
CLAUDE_API_KEY=test-dummy-claude-api-key

# WordPress Test Environment
NEXT_PUBLIC_WP_ENDPOINT=http://localhost:8080/graphql
WORDPRESS_AUTH_TOKEN=test-dummy-wordpress-token

# Firebase Test Config (using emulator)
NEXT_PUBLIC_FIREBASE_API_KEY=test-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=test-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=test-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=test-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-TEST123