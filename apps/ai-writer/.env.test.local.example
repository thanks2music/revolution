# .env.test.local.example
#
# Copy this file to `.env.test.local` and fill in real API keys to enable
# local E2E testing.
#
#   cp .env.test.local.example .env.test.local
#
# `.env.test.local` is gitignored (Next.js convention).
# See: https://nextjs.org/docs/pages/guides/environment-variables#test-environment-variables
#
# WARNING: pnpm test:e2e calls real APIs and incurs cost (~$0.03/run for Claude,
# ~$0.001/run for OpenAI). Run intentionally — not on every commit / not in pre-push
# / not via Stop hooks. See docs/e2e-testing.md for details.

# ---------------------------------------------------------------------------
# Anthropic Claude API key
# ---------------------------------------------------------------------------
# Format: sk-ant-...
# Leave empty to skip Claude E2E tests (it.skip with reason)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI API key
# ---------------------------------------------------------------------------
# Format: sk-... (legacy) or sk-proj-... (new)
# Leave empty to skip OpenAI E2E tests (it.skip with reason)
OPENAI_API_KEY=
